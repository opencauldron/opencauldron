{
  "name": "opencauldron",
  "version": "0.1.0",
  "private": false,
  "packageManager": "pnpm@10.5.2",
  "description": "Open source AI media generation studio. Generate images and videos with 10+ AI models from a single interface.",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/opencauldron/opencauldron.git"
  },
  "author": "OpenCauldron",
  "scripts": {
    "dev": "next dev --port 9999",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:append-only": "node scripts/check-activity-append-only.mjs",
    "backfill:activity": "node scripts/backfill-activity.mjs",
    "test": "vitest run",
    "test:e2e": "E2E_ENABLED=true vitest run --config vitest.e2e.config.ts",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "bootstrap": "tsx scripts/bootstrap-self-hosted.ts",
    "verify-migration": "tsx scripts/verify-migration.ts",
    "migrate-refs": "tsx scripts/migrate-references-to-assets.ts",
    "setup": "node scripts/setup.mjs"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.1",
    "@aws-sdk/client-s3": "^3.1014.0",
    "@aws-sdk/s3-request-presigner": "^3.1014.0",
    "@base-ui/react": "^1.3.0",
    "@google/generative-ai": "^0.24.1",
    "@mistralai/mistralai": "^2.1.1",
    "@neondatabase/serverless": "^1.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "emoji-picker-element": "^1.29.1",
    "lucide-react": "^0.577.0",
    "nanoid": "^5.1.7",
    "next": "16.2.1",
    "next-auth": "5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@clack/prompts": "^1.3.0",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "eventsource": "^4.1.0",
    "picocolors": "^1.1.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.1"
  }
}
