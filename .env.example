# ============================================
# REQUIRED — App won't start without these
# ============================================
#
# For Docker self-host installs, set the values below in this file (.env)
# and run `docker compose up -d`. The container's entrypoint will:
#   - generate NEXTAUTH_SECRET if empty (and persist it across restarts)
#   - run all pending Drizzle migrations
#   - if WORKSPACE_NAME and ADMIN_EMAIL are set AND no workspace exists yet,
#     auto-create the admin's workspace + Personal brand on first boot
#
# Already-running installs ignore WORKSPACE_NAME / ADMIN_EMAIL — they only
# matter on the very first `docker compose up`.

# Database — defaults to the bundled Postgres service in docker-compose.yml.
# Point at any TCP Postgres (Neon, Supabase, RDS, …) by changing this URL.
DATABASE_URL="postgresql://cauldron:cauldron@db:5432/cauldron"

# Auth — public URL where the app is reachable.
NEXTAUTH_URL="http://localhost:3000"

# Auth signing secret. Leave empty for Docker installs — the entrypoint
# generates a 32-byte base64 secret on first boot and persists it to the
# `app-state` volume so it survives image upgrades. To set one explicitly
# (e.g., for a hosted/Vercel deploy), generate via: openssl rand -base64 32
NEXTAUTH_SECRET=""

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# First-boot bootstrap — only required on a fresh install. Leave blank
# after the first successful boot; subsequent restarts ignore them.
#
#   WORKSPACE_NAME — your studio name, e.g. "Acme Studio"
#   ADMIN_EMAIL    — the Google email that will become workspace owner
#
# If these are missing on a database with no workspace, the container exits
# non-zero with an instruction (no half-bootstrapped state).
WORKSPACE_NAME=""
ADMIN_EMAIL=""

# ============================================
# OPTIONAL — Customize behavior
# ============================================

# Workspace mode — `hosted` for SaaS multi-tenant deployments, `self_hosted` for
# Docker / on-prem installs. The Docker entrypoint defaults this to
# `self_hosted` automatically; only set it here if you're not using Docker
# (e.g., running `pnpm dev` directly).
WORKSPACE_MODE="self_hosted"

# Trust the incoming Host header. NextAuth v5 requires this on non-Vercel
# deployments. The Docker entrypoint defaults it to `true` automatically;
# only set it here if you're running the app outside the container.
# AUTH_TRUST_HOST="true"

# Phase 2 collections / share-link surface. Leave `false` in MVP — flips on when
# collections UI ships.
FEATURE_SHARED_WITH_YOU="false"

# Restrict sign-in to a specific email domain (leave empty to allow all)
# ALLOWED_EMAIL_DOMAIN=""

# Organization branding (shown on login page)
# NEXT_PUBLIC_ORG_NAME=""          # e.g. "Acme Corp"
# NEXT_PUBLIC_ORG_LOGO=""          # e.g. "/logos/acme.png"
# NEXT_PUBLIC_ORG_URL=""           # e.g. "https://acme.com"
# NEXT_PUBLIC_STUDIO_NAME=""       # e.g. "Acme Studio" (defaults to org name)

# ============================================
# STORAGE — Choose one
# ============================================

# Option 1: Local filesystem (easiest for development)
STORAGE_PROVIDER="local"

# Option 2: Cloudflare R2 (production)
# STORAGE_PROVIDER="r2"
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET_NAME="cauldron"
# R2_PUBLIC_URL=""

# ============================================
# AI MODELS — Add keys for models you want to use
# (models without keys are automatically hidden)
# ============================================

# Google Gemini (Imagen 4, Flash, Lite + Veo 3 video)
# GEMINI_API_KEY=""

# xAI (Grok Imagine, Grok Pro)
# XAI_API_KEY=""

# Black Forest Labs (Flux Pro, Flux Dev)
# BFL_API_KEY=""

# Ideogram (text-in-image specialist)
# IDEOGRAM_API_KEY=""

# Recraft (design & vector art)
# RECRAFT_API_KEY=""

# OpenAI (gpt-image-1.5, gpt-image-1, gpt-image-1-mini)
# OPENAI_API_KEY=""

# Runway (Gen-4 Turbo video)
# RUNWAY_API_KEY=""

# FAL.ai (Kling video, Wan video + LoRA, Flux LoRA)
# FAL_KEY=""

# Civitai (LoRA browsing — optional, enables higher rate limits)
# CIVITAI_API_KEY=""

# MiniMax (Hailuo video)
# MINIMAX_API_KEY=""

# Luma AI (Ray-2 video)
# LUMA_API_KEY=""

# Mistral (prompt enhancement)
# MISTRAL_API_KEY=""

# ============================================
# LIBRARY / DAM — Embedding pipeline
# ============================================

# Library/DAM feature flag — when "false" the /library route + /api/library
# endpoints respond with 404 and the sidebar still points at /references. Flip
# to "true" once the unified Library is ready to ship to all users.
LIBRARY_DAM_ENABLED="false"

# Replicate (CLIP image embeddings — andreasjansson/clip-features)
# Without this token the embedding worker is a no-op; semantic search falls
# back to text-only.
# REPLICATE_API_TOKEN=""

# Embedding model identifier persisted on each row so a future model swap is
# reversible per-asset. Keep in sync with EMBEDDING_DIM.
EMBEDDING_MODEL="andreasjansson/clip-features"
EMBEDDING_DIM="768"

# Worker tuning. Batch size is the max rows the cron tick will pull per run;
# cron interval is the minutes between Vercel cron invocations.
EMBEDDING_BATCH_SIZE="50"
EMBEDDING_CRON_INTERVAL_MIN="2"

# ============================================
# DEV-ONLY — never enable in production
# ============================================

# Dev-login shortcut at `/api/dev-login`. When set to "true" AND `NODE_ENV`
# is not "production", a query-param-driven endpoint mints an authenticated
# session for the named user — used exclusively by automated browser QA
# (`agent-browser`) so end-to-end runs can skip the Google OAuth dance.
#
# Defense-in-depth:
#   * The route returns 404 unless BOTH conditions hold (NODE_ENV !==
#     "production" AND DEV_LOGIN_ENABLED === "true").
#   * `next.config.ts` aborts the production build when this flag is "true".
#   * Every successful mint logs a loud `[dev-login]` console.warn so a stray
#     activation in any environment is impossible to miss.
#
# NEVER set this in a production environment. It bypasses Google OAuth
# entirely and would let anyone with knowledge of an existing user's email
# impersonate them.
# DEV_LOGIN_ENABLED="false"
