# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies — project uses pnpm; npm/yarn/bun lockfiles are excluded
/node_modules
/.pnp
.pnp.*
package-lock.json
yarn.lock
bun.lock
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local uploads
/uploads/

# internal docs — deny everything in docs/, allow-list public ones below
OPEN_SOURCE_SPEC.md
/specs/
docs/*
!docs/CODE_OF_CONDUCT.md
!docs/CONTRIBUTING.md

# org-specific branding (local only, not committed to open source)
public/logos/taboogrow.png

# claude code local tooling — deny by default, allow-list shared skills
.claude/agent-memory/
.claude/settings.local.json
.claude/worktrees/
.claude/agents/
.claude/skills/*
!.claude/skills/integrate-provider/
!.claude/skills/update-changelog/
/skills/
skills-lock.json
